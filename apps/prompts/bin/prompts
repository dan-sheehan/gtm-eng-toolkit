#!/usr/bin/env python3
import json
import os
import sys
from pathlib import Path

CONFIG_PATH = Path.home() / ".promptlib" / "config.json"


def load_app_root():
    env_root = os.environ.get("PROMPTS_APP_ROOT")
    if env_root:
        return env_root

    # If this launcher is executed via a symlink, resolve to the real path and
    # infer the app root from the repository layout: prompts/bin/prompts.
    resolved = Path(__file__).resolve()
    inferred_root = resolved.parent.parent
    if (inferred_root / "prompts.py").exists():
        return str(inferred_root)

    if CONFIG_PATH.exists():
        try:
            data = json.loads(CONFIG_PATH.read_text())
        except json.JSONDecodeError:
            return None
        return data.get("app_root")
    return None


def main():
    app_root = load_app_root()
    if not app_root:
        sys.stderr.write(
            "Prompts app root not set. Set PROMPTS_APP_ROOT or run from the repo once.\n"
        )
        return 1

    script = Path(app_root) / "prompts.py"
    if not script.exists():
        sys.stderr.write(f"prompts.py not found at {script}\n")
        return 1

    os.execvp("python3", ["python3", str(script), *sys.argv[1:]])


if __name__ == "__main__":
    raise SystemExit(main())
